{% extends 'base.html.twig' %}

{% block title %}Envoi du mail pour changement de mot de passe!{% endblock %}

{% block body %}
    <main class="main-form main-reset">
        <div class="container">
            <div class="section-box">
                <div class="form-display">
                    <div>
                        <h1>Nouveau mot de passe</h1>
                    </div>
                    {{ form_start(resetForm) }}
                        <div class="form-field">
                            {{ form_label(resetForm.plainPassword.first) }}
                            {{ form_errors(resetForm.plainPassword.first) }}
                            {{ form_widget(resetForm.plainPassword.first) }}
                        </div>

                        <div class="form-field">
                            {{ form_label(resetForm.plainPassword.second) }}
                            {{ form_errors(resetForm.plainPassword.second) }}
                            {{ form_widget(resetForm.plainPassword.second) }}
                        </div>
                        <div class="bloc-btn">
                            <button class="btn" type="submit">Modifier le mot de passe</button>                        
                        </div>
                    {{ form_end(resetForm) }}
                </div>
            </div>
        </div>
    </main>
{% endblock %}
